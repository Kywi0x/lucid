# Copie ce fichier en .env et remplis les valeurs.
# .env est gitignore — ne jamais committer les valeurs réelles.

# Google OAuth 2.0 — Desktop app (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=VOTRE_CLIENT_SECRET

# Supabase — compte + sauvegarde cloud (Settings → API dans le dashboard)
# La clé anon est publique par design (protégée par les policies RLS).
VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE_ANON_KEY
